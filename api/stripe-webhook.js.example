// EXAMPLE FILE — rename to `stripe-webhook.js` once you're ready.
//
// A webhook isn't strictly required for the simple flow in
// src/lib/monetization.js (which just reads a `?unlocked=true` param off
// the success redirect) — Stripe only sends someone back to your
// success_url after payment actually succeeds, so that alone is a
// reasonable signal for a $2-3 one-time unlock with nothing sensitive
// behind it.
//
// A webhook is worth adding if you want a source of truth that doesn't
// depend on the browser faithfully completing the redirect (e.g. someone
// closes the tab mid-flow) — but note this app has no database, so even
// with a webhook there's nowhere server-side to durably record "this
// browser paid." A real implementation would need to either add a
// database at that point, or use the webhook only for your own
// bookkeeping (email receipts, logging, fraud checks) while still relying
// on the client-side redirect flag for the actual unlock — which is what
// the current scaffold does.
//
// Set STRIPE_WEBHOOK_SECRET as a Vercel environment variable, and
// register this endpoint's URL in your Stripe Dashboard under
// Developers → Webhooks.

import Stripe from 'stripe';

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY);

export const config = {
  api: { bodyParser: false }, // Stripe needs the raw request body to verify the signature
};

async function getRawBody(req) {
  const chunks = [];
  for await (const chunk of req) chunks.push(chunk);
  return Buffer.concat(chunks);
}

export default async function handler(req, res) {
  const sig = req.headers['stripe-signature'];
  const rawBody = await getRawBody(req);

  let event;
  try {
    event = stripe.webhooks.constructEvent(rawBody, sig, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err) {
    console.error('Webhook signature verification failed:', err.message);
    return res.status(400).json({ error: 'Invalid signature' });
  }

  if (event.type === 'checkout.session.completed') {
    console.log('Payment completed:', event.data.object.id);
    // No database here to persist this against — see note above.
  }

  res.status(200).json({ received: true });
}
